{
  "name": "ku9-player",
  "version": "1.0.0",
  "description": "KU9 Player - 完全自主可控的直播播放器，支持桌面端(Windows/macOS/Linux)和移动端(Android)打包",
  "main": "electron/main.js",
  "author": "KU9 Team",
  "license": "MIT",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd electron && npm install",
    "dev:web": "npx serve src -l 3000",
    "dev:electron": "cd electron && npm run dev",
    "build:electron:win": "cd electron && npx electron-builder --win --x64 --publish never",
    "build:electron:mac": "cd electron && npx electron-builder --mac --x64 --publish never",
    "build:electron:linux": "cd electron && npx electron-builder --linux --x64 --publish never",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "build:android:debug": "npm run cap:sync && cd android && ./gradlew assembleDebug --stacktrace",
    "build:android:release": "npm run cap:sync && cd android && ./gradlew assembleRelease --stacktrace",
    "clean": "rimraf dist node_modules electron/node_modules electron/dist android/app/build android/.gradle"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "rimraf": "^5.0.5",
    "serve": "^14.2.3"
  },
  "dependencies": {
    "@capacitor-community/keep-awake": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/ku9-player.git"
  },
  "keywords": [
    "iptv",
    "player",
    "m3u8",
    "hls",
    "live-streaming",
    "electron",
    "capacitor",
    "android"
  ],
  "bugs": {
    "url": "https://github.com/yourusername/ku9-player/issues"
  },
  "homepage": "https://github.com/yourusername/ku9-player#readme"
}
